# Copy to .env and fill in. Loaded by app.config.Settings at startup.
S3_BUCKET=demo-bucket-20260524
S3_REGION=us-east-1

# Local dev with moto/MinIO — set this to e.g. http://localhost:9000.
# Leave empty to use the real AWS endpoint.
# S3_ENDPOINT_URL=

# Comma-separated CORS origins for the frontend dev server.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
